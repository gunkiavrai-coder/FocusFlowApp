# Supabase — https://supabase.com/dashboard/project/TON_PROJECT/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://TON_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=ta_anon_key

# Claude AI — https://console.anthropic.com/settings/keys
# Mettre "true" pour activer l'IA (nécessite des crédits Anthropic)
# Laisser "false" pour utiliser le planning local gratuit
EXPO_PUBLIC_USE_AI=false

# Utilisé uniquement par l'Edge Function Supabase (pas dans l'app)
ANTHROPIC_API_KEY=sk-ant-...
